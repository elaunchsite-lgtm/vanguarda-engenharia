---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { config } from '../lib/config';

interface Props {
  activePage?: string;
}

const { activePage = "home" } = Astro.props;

const navItems = config.navigation && config.navigation.length > 0 ? config.navigation : [
  { label: 'Início', href: '/' },
  { label: 'Sobre Nós', href: '/sobre' },
  { label: 'Blog & Artigos', href: '/blog' },
  { label: 'Contato', href: '/contato' },
];
---

<header class="w-full relative z-50 shadow-md">
  {/* Top utility contact info bar */}
  <div class="bg-slate-900 text-slate-300 py-2.5 px-4 sm:px-6 lg:px-8 border-b border-slate-800 text-xs hidden md:block">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <div class="flex items-center space-x-6">
        <span class="flex items-center space-x-1.5">
          <Icon name="Clock" class="w-3.5 h-3.5 text-brand-primary" />
          <span>{config.contactHours || 'Seg - Sab: 07:00 - 18:00'}</span>
        </span>
        <span class="flex items-center space-x-1.5">
          <Icon name="Phone" class="w-3.5 h-3.5 text-brand-primary" />
          <span>{config.contactPhone || '+55 (11) 3088-5555'}</span>
        </span>
        <span class="flex items-center space-x-1.5">
          <Icon name="Mail" class="w-3.5 h-3.5 text-brand-primary" />
          <span>{config.contactEmail || 'contato@vanguardaengenharia.com'}</span>
        </span>
      </div>
      <div class="flex items-center space-x-4">
        {config.socialFacebook && (
          <a href={config.socialFacebook} aria-label="Facebook" target="_blank" rel="noopener" class="hover:text-brand-primary transition-colors">
            <Icon name="Facebook" class="w-3.5 h-3.5" />
          </a>
        )}
        {config.socialTwitter && (
          <a href={config.socialTwitter} aria-label="Twitter" target="_blank" rel="noopener" class="hover:text-brand-primary transition-colors">
            <Icon name="Twitter" class="w-3.5 h-3.5" />
          </a>
        )}
        {config.socialLinkedin && (
          <a href={config.socialLinkedin} aria-label="LinkedIn" target="_blank" rel="noopener" class="hover:text-brand-primary transition-colors">
            <Icon name="Linkedin" class="w-3.5 h-3.5" />
          </a>
        )}
        {config.socialInstagram && (
          <a href={config.socialInstagram} aria-label="Instagram" target="_blank" rel="noopener" class="hover:text-brand-primary transition-colors">
            <Icon name="Instagram" class="w-3.5 h-3.5" />
          </a>
        )}
      </div>
    </div>
  </div>

  {/* Main navigation header */}
  <div data-no-edit class="bg-white text-slate-900 py-4 px-4 sm:px-6 lg:px-8 border-b border-slate-100">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      {/* Brand Logo */}
      <a 
        href="/" 
        class="flex items-center space-x-2.5 text-left focus:outline-none cursor-pointer group"
      >
        {config.logoUrl ? (
          <Image src={config.logoUrl} alt={config.siteName} width={800} height={450} densities={[1, 2]} class="h-10 w-auto object-contain" />
        ) : (
          <div class="bg-slate-950 text-brand-primary p-2 rounded group-hover:bg-brand-primary group-hover:text-slate-950 transition-colors duration-300">
            <Icon name="Building2" class="w-6 h-6" />
          </div>
          <div>
            <span class="font-display font-bold text-lg md:text-xl tracking-tight text-slate-950 block">
              {config.siteName}
            </span>
            <span class="font-mono text-[10px] tracking-widest text-slate-500 block -mt-1 uppercase">
              Engenharia & Construção
            </span>
          </div>
        )}
      </a>

      {/* Desktop Navigation */}
      <nav class="hidden md:flex items-center space-x-8">
        {navItems.map((item) => {
          // Determine if current link is active based on path
          const isActive = Astro.url.pathname === item.href || 
            (item.href !== '/' && Astro.url.pathname.startsWith(item.href)) ||
            (item.href === '/blog' && activePage === 'blog');
          return (
            <a
              href={item.href}
              class={`font-display text-sm font-semibold uppercase tracking-wider relative py-2 transition-colors cursor-pointer ${
                isActive ? 'text-brand-primary' : 'text-slate-700 hover:text-brand-primary'
              }`}
            >
              {item.label}
              {isActive && (
                <span class="absolute bottom-0 left-0 w-full h-0.5 bg-brand-primary" />
              )}
            </a>
          );
        })}
        <a
          href="/contato"
          class="bg-brand-primary text-slate-950 px-5 py-2.5 rounded font-display text-xs font-bold uppercase tracking-wider hover:bg-slate-950 hover:text-brand-primary transition-all duration-300 shadow-sm cursor-pointer"
        >
          Fale Conosco
        </a>
      </nav>

      {/* Mobile menu trigger */}
      <div class="md:hidden flex items-center space-x-4">
        <a
          href="/contato"
          class="bg-brand-primary text-slate-950 px-3 py-1.5 rounded font-display text-[10px] font-bold uppercase tracking-wider"
        >
          Fale Conosco
        </a>
        <button
          id="mobile-menu-toggle"
          class="p-1.5 rounded text-slate-700 hover:bg-slate-100"
          aria-label="Abrir menu"
        >
          <Icon name="Menu" class="w-6 h-6" />
        </button>
      </div>
    </div>
  </div>

  {/* Mobile Drawer */}
  <div 
    id="mobile-drawer"
    class="hidden md:hidden bg-white border-b border-slate-200 absolute top-full left-0 w-full py-4 px-6 shadow-xl z-50 animate-in fade-in slide-in-from-top-4 duration-200"
  >
    <div class="flex flex-col space-y-4">
      {navItems.map((item) => {
        const isActive = Astro.url.pathname === item.href || 
          (item.href !== '/' && Astro.url.pathname.startsWith(item.href)) ||
          (item.href === '/blog' && activePage === 'blog');
        return (
          <a
            href={item.href}
            class={`text-left font-display font-bold text-sm uppercase tracking-wider py-2 border-b border-slate-100 ${
              isActive ? 'text-brand-primary' : 'text-slate-700'
            }`}
          >
            {item.label}
          </a>
        );
      })}
      <div class="pt-2 flex flex-col space-y-3">
        <span class="text-xs text-slate-500 flex items-center space-x-2">
          <Icon name="Clock" class="w-3.5 h-3.5 text-brand-primary" />
          <span>Seg - Sáb: 07:00 - 18:00</span>
        </span>
        <span class="text-xs text-slate-500 flex items-center space-x-2">
          <Icon name="Phone" class="w-3.5 h-3.5 text-brand-primary" />
          <span>+55 (11) 3088-5555</span>
        </span>
      </div>
    </div>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const drawer = document.getElementById('mobile-drawer');

  if (toggleBtn && drawer) {
    toggleBtn.addEventListener('click', () => {
      drawer.classList.toggle('hidden');
    });
  }
</script>
