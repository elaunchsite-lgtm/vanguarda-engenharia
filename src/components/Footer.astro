---
import { Image } from 'astro:assets';
import Icon from './Icon.astro';
import { config } from '../lib/config';

const currentYear = new Date().getFullYear();
const tags = ['Construção', 'BIM', 'Retrofit', 'Arquitetura', 'Gestão de Obras', 'Sustentabilidade', 'Engenharia Civil', 'Concreto', 'Estruturas', 'Luminotécnica'];

const navItems = config.navigation && config.navigation.length > 0 ? config.navigation : [
  { label: 'Início', href: '/' },
  { label: 'Sobre Nós', href: '/sobre' },
  { label: 'Blog & Artigos', href: '/blog' },
  { label: 'Contato', href: '/contato' },
];
---

<footer class="bg-slate-950 text-slate-400 font-sans border-t border-slate-900">
  {/* Primary footer widgets */}
  <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
    {/* Info & Logo Widget */}
    <div class="flex flex-col space-y-6">
      <a 
        href="/"
        class="flex items-center space-x-2.5 text-left focus:outline-none cursor-pointer self-start group"
      >
        {config.logoUrl ? (
          <Image src={config.logoUrl} alt={config.siteName} width={800} height={450} densities={[1, 2]} class="h-10 w-auto object-contain" />
        ) : (
          <div class="bg-brand-primary text-slate-950 p-2 rounded group-hover:bg-white transition-colors duration-300">
            <Icon name="Building2" class="w-6 h-6" />
          </div>
          <div>
            <span class="font-display font-bold text-lg tracking-tight text-white block">
              {config.siteName}
            </span>
            <span class="font-mono text-[9px] tracking-widest text-brand-primary block -mt-1 uppercase">
              Engenharia & Construção
            </span>
          </div>
        )}
      </a>
      <p class="text-sm leading-relaxed text-slate-400">
        {config.footerAbout || 'Erguendo infraestruturas sólidas, edifícios icônicos e residências ecológicas de alto padrão com precisão cirúrgica e o que há de mais inovador na engenharia civil nacional.'}
      </p>
      <div class="flex space-x-4">
        {config.socialFacebook && (
          <a href={config.socialFacebook} target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-slate-900 hover:bg-brand-primary hover:text-slate-950 flex items-center justify-center text-xs font-bold text-slate-400 transition-colors cursor-pointer">FB</a>
        )}
        {config.socialLinkedin && (
          <a href={config.socialLinkedin} target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-slate-900 hover:bg-brand-primary hover:text-slate-950 flex items-center justify-center text-xs font-bold text-slate-400 transition-colors cursor-pointer">LK</a>
        )}
        {config.socialInstagram && (
          <a href={config.socialInstagram} target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-slate-900 hover:bg-brand-primary hover:text-slate-950 flex items-center justify-center text-xs font-bold text-slate-400 transition-colors cursor-pointer">IG</a>
        )}
        {config.socialYoutube && (
          <a href={config.socialYoutube} target="_blank" rel="noopener" class="w-8 h-8 rounded-full bg-slate-900 hover:bg-brand-primary hover:text-slate-950 flex items-center justify-center text-xs font-bold text-slate-400 transition-colors cursor-pointer">YT</a>
        )}
      </div>
    </div>

    {/* Quick Navigation Widget */}
    <div class="flex flex-col space-y-5">
      <h3 class="font-display font-bold text-white uppercase tracking-wider text-sm border-l-2 border-brand-primary pl-3">
        Navegação Rápida
      </h3>
      <ul data-no-edit class="space-y-3.5 text-sm">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href} 
              class="hover:text-brand-primary flex items-center space-x-2 transition-colors cursor-pointer"
            >
              <Icon name="ArrowRight" class="w-3 h-3 text-brand-primary" />
              <span>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    {/* Tags / Specializations Widget */}
    <div class="flex flex-col space-y-5">
      <h3 class="font-display font-bold text-white uppercase tracking-wider text-sm border-l-2 border-brand-primary pl-3">
        Especialidades
      </h3>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span 
            class="bg-slate-900 text-slate-300 px-2.5 py-1 text-xs rounded border border-slate-800 hover:border-brand-primary transition-colors"
          >
            {tag}
          </span>
        ))}
      </div>
      <div class="pt-2 flex flex-col space-y-2 text-xs">
        {config.footerEmergency && (
          <span class="flex items-center space-x-2 text-slate-500">
            <Icon name="Clock" class="w-3.5 h-3.5 text-brand-primary" />
            <span>{config.footerEmergency}</span>
          </span>
        )}
      </div>
    </div>

    {/* Contact info widget */}
    <div class="flex flex-col space-y-5">
      <h3 class="font-display font-bold text-white uppercase tracking-wider text-sm border-l-2 border-brand-primary pl-3">
        Sede Principal
      </h3>
      <ul class="space-y-4 text-sm">
        <li class="flex items-start space-x-3">
          <Icon name="MapPin" class="w-5 h-5 text-brand-primary shrink-0 mt-0.5" />
          <span>{config.contactAddress || 'Av. Brigadeiro Faria Lima, 3477 - 14º Andar, Itaim Bibi, São Paulo - SP, CEP 04538-133'}</span>
        </li>
        <li class="flex items-center space-x-3">
          <Icon name="Phone" class="w-4 h-4 text-brand-primary shrink-0" />
          <span>{config.contactPhone || '+55 (11) 3088-5555'}</span>
        </li>
        <li class="flex items-center space-x-3">
          <Icon name="Mail" class="w-4 h-4 text-brand-primary shrink-0" />
          <span class="break-all">contato@vanguardaengenharia.com</span>
        </li>
      </ul>
    </div>
  </div>

  {/* Compliance / Legal Links & Copyright */}
  <div class="bg-slate-950 border-t border-slate-900 py-6 px-4 sm:px-6 lg:px-8 text-xs text-slate-500">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
      <div>
        <span>&copy; {currentYear} {config.siteName} &amp; Construção Ltda. CNPJ 12.345.678/0001-90. Todos os direitos reservados.</span>
      </div>
      <div data-no-edit class="flex items-center gap-2">
        <span>Desenvolvido por</span>
        <a href="https://e-launch.com.br" target="_blank" rel="noopener" class="text-brand-primary hover:text-white font-bold transition-colors">E-Launch</a>
      </div>
      <div data-no-edit class="flex items-center space-x-6">
        <a 
          href="/politica-de-privacidade"
          class="hover:text-white flex items-center space-x-1.5 transition-colors cursor-pointer"
        >
          <Icon name="ShieldCheck" class="w-3.5 h-3.5 text-brand-primary" />
          <span>Política de Privacidade</span>
        </a>
        <a 
          href="/termos-de-uso"
          class="hover:text-white flex items-center space-x-1.5 transition-colors cursor-pointer"
        >
          <Icon name="Scale" class="w-3.5 h-3.5 text-brand-primary" />
          <span>Termos de Uso</span>
        </a>
      </div>
    </div>
  </div>
</footer>
